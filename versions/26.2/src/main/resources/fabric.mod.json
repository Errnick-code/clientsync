{
  "schemaVersion": 1,
  "id": "clientsync",
  "version": "${version}",
  "name": "ClientSync",
  "description": "Client-side companion for the ClientSync modpack installer, keeping your mods and files synced with the server.",
  "authors": [
    "Errnick_"
  ],
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.errnicraft.clientsync.server.ServerModInit"
    ],
    "client": [
      "dev.errnicraft.clientsync.ClientSyncMod"
    ]
  },
  "mixins": [
    "clientsync.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "fabric-api": "*",
    "minecraft": "26.2"
  },
  "icon": "assets/clientsync/icon.png"
}
